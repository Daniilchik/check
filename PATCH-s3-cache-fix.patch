+def _clear_s3_client_cache(username):
+    """
+    Сбросить кэшированный per-user S3-клиент юзера в Hue fsmanager.
+    Нужно, т.к. клиент кэшируется с запечёнными credentials — после смены
+    ключей (login/logout) старый клиент надо выкинуть, чтобы он пересобрался
+    с актуальными session-ключами. Работает только если кэш per-user
+    (см. patch._patch_per_user_s3_cache).
+    """
+    try:
+        from desktop.lib import fsmanager
+        if getattr(fsmanager, "CLIENT_CACHE", None):
+            fsmanager.clear_cached_client("default", username)
+    except Exception as e:
+        log.warning("ozone_s3_creds: clear S3 client cache failed for %s: %s",
+                    username, e)
+
+
