+def _patch_per_user_s3_cache():
+    # Hue кэширует S3-клиент в fsmanager.CLIENT_CACHE. Ключ включает username
+    # ТОЛЬКО если fsmanager._is_per_user_fs_cached(fs) == True, что требует
+    # aws.conf.GET_USER_CREDENTIALS_FROM_SECMAN=True. У нас secman выключен →
+    # кэш ОБЩИЙ (один S3-клиент на всех юзеров), строится один раз и запекает
+    # credentials. Для per-session ключей это фатально: первый кто построил
+    # клиент (во время login, с пустым thread-local → fallback) фиксирует
+    # fallback для всех.
+    #
+    # Патчим _is_per_user_fs_cached → True для s3a: кэш становится per-user,
+    # и clear_cached_client(name, user) начинает работать (см. signals.py).
+    try:
+        from desktop.lib import fsmanager
+    except ImportError:
+        log.warning("fsmanager not importable, skipping per-user S3 cache patch")
+        return
+
+    original = fsmanager._is_per_user_fs_cached
+
+    def patched(fs):
+        if fs == "s3a":
+            return True
+        return original(fs)
+
+    fsmanager._is_per_user_fs_cached = patched
+    log.info("ozone_s3_creds: monkey-patched fsmanager._is_per_user_fs_cached for s3a")
+
+
 def install():
     _patch_credential_provider()
     _patch_proxyfs_has_access()
+    _patch_per_user_s3_cache()
